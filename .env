# Base URL of the driveinnovate API server.
# In production the website (driveinnovate.in) and API share the same origin,
# so the default works out of the box. Override for local dev pointing at
# a local server (e.g. http://localhost:5000).
# VITE_API_BASE=https://server.driveinnovate.in
VITE_API_BASE=https://driveinnovate-server.onrender.com/api
